      <block id="ID1413071801">
        <id>Values</id>
        <ml id="ID1413071988">val AllCustomers = [
(&quot;Nordica Systems GmbH&quot;, &quot;Wil van der Aalst&quot;, &quot;Istvan Koren&quot;),
(&quot;AlpenTech Innovations AG&quot;, &quot;Wil van der Aalst&quot;, &quot;Istvan Koren&quot;),
(&quot;Baltic Wave Energies Ltd.&quot;, &quot;Wil van der Aalst&quot;, &quot;Christine von Dobbert&quot;),
(&quot;Mediterranea Luxury Cruises S.p.A.&quot;, &quot;Wil van der Aalst&quot;, &quot;Christine von Dobbert&quot;),
(&quot;Pantheon Art Gallery Kft.&quot;, &quot;Istvan Koren&quot;, &quot;Christine von Dobbert&quot;),
(&quot;Riviera Robotics SAS&quot;, &quot;Istvan Koren&quot;, &quot;Christine von Dobbert&quot;),
(&quot;Celtica Green Farms Oy&quot;, &quot;Istvan Koren&quot;, &quot;Mara Nitschke&quot;),
(&quot;Balkan Minerals d.o.o.&quot;, &quot;Christine von Dobbert&quot;, &quot;Mara Nitschke&quot;),
(&quot;Iberian Sun Solaridades SA&quot;, &quot;Christine von Dobbert&quot;, &quot;Mara Nitschke&quot;),
(&quot;Danube Pharmaceuticals BV&quot;, &quot;Christine von Dobbert&quot;, &quot;Mara Nitschke&quot;),
(&quot;SwissPeak Timepieces AG&quot;, &quot;Christine von Dobbert&quot;, &quot;Jan Niklas Adams&quot;),
(&quot;Carpathian Financial Services plc&quot;, &quot;Jan Niklas Adams&quot;, &quot;Istvan Koren&quot;),
(&quot;Vesta Fashion House GmbH&quot;, &quot;Jan Niklas Adams&quot;, &quot;Istvan Koren&quot;),
(&quot;Eastern Oak Insurance Zrt.&quot;, &quot;Mara Nitschke&quot;, &quot;Istvan Koren&quot;),
(&quot;Golden Fleece Textiles S.A.R.L.&quot;, &quot;Mara Nitschke&quot;, &quot;Jan Niklas Adams&quot;)
]: Customers
          <layout>val AllCustomers = [
(&quot;Nordica Systems GmbH&quot;, &quot;Wil van der Aalst&quot;, &quot;Istvan Koren&quot;),
(&quot;AlpenTech Innovations AG&quot;, &quot;Wil van der Aalst&quot;, &quot;Istvan Koren&quot;),
(&quot;Baltic Wave Energies Ltd.&quot;, &quot;Wil van der Aalst&quot;, &quot;Christine von Dobbert&quot;),
