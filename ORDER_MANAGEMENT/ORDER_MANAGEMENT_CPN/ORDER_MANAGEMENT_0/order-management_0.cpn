        <ml id="ID1413074668">fun nof_items(infl: Inflation) = real(poisson(2.0*(1.0-infl/100.0)) + 1);
          <layout>fun nof_items(infl: Inflation) = real(poisson(2.0*(1.0-infl/100.0)) + 1);</layout>
        </ml>
        <ml id="ID1418466215">fun contains_pid([], _) = false | contains_pid((prod,weight,price)::pis, (prod2, w2,p2)) = if prod=prod2 then true else
contains_pid(pis,(prod2,w2,p2));
