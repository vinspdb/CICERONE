        </ml>
        <ml id="ID1413420106">fun fiids([]:Items) = [] | fiids((iid,pi,cust,oid)::its:Items) = [iid]^^fiids(its);
          <layout>fun fiids([]:Items) = [] | fiids((iid,pi,cust,oid)::its:Items) = [iid]^^fiids(its);</layout>
