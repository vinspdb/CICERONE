        </ml>
        <ml id="ID1413299007">fun fitscust([]:Items) = &quot;missing&quot;| fitscust(item::its:Items) = ficust(item);
          <layout>fun fitscust([]:Items) = &quot;missing&quot;| fitscust(item::its:Items) = ficust(item);</layout>
        </ml>
        <ml id="ID1413245893">fun fsame(item:Item,[]:Items)= [item] | 
fsame(item:Item,item2::its:Items)= if ficust(item)=ficust(item2) then [item2]^^fsame(item,its) else fsame(item,its);
          <layout>fun fsame(item:Item,[]:Items)= [item] | 
fsame(item:Item,item2::its:Items)= if ficust(item)=ficust(item2) then [item2]^^fsame(item,its) else fsame(item,its);</layout>
        </ml>
        <ml id="ID1413256074">fun fdiff(item:Item,[]:Items)= [] | 
fdiff(item:Item,item2::its:Items)= if ficust(item)=ficust(item2) then fdiff(item,its) else [item2]^^fdiff(item,its);
          <layout>fun fdiff(item:Item,[]:Items)= [] | 
fdiff(item:Item,item2::its:Items)= if ficust(item)=ficust(item2) then fdiff(item,its) else [item2]^^fdiff(item,its);</layout>
        </ml>
        <ml id="ID1414083487">fun remove (x,[]) = [] | remove (x,y::ys) = if x = y then remove(x,ys) else y::remove(x,ys)
          <layout>fun remove (x,[]) = [] | remove (x,y::ys) = if x = y then remove(x,ys) else y::remove(x,ys)</layout>
        </ml>
        <ml id="ID1414083202">fun clean([]) = [] | clean(x::xs) = x::clean(remove(x,xs));
          <layout>fun clean([]) = [] | clean(x::xs) = x::clean++(remove(x,xs));</layout>
        </ml>
        <ml id="ID1413608112">fun fbool(x) = if uniform(0.0,1.0) &lt; x then true else false;
          <layout>fun fbool(x) = if uniform(0.0,1.0) &lt; x then true else false;</layout>
        </ml>
